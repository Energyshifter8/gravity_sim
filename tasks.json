{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "cppbuild",
      "command": "/usr/bin/g++",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${workspaceFolder}/src/gravity_sim_3Dgrid.cpp",
        "-o",
        "${workspaceFolder}/src/gravity_sim_3Dgrid",
        "-lGLEW",
        "-lglfw",
        "-lGL",
        "-lGLU",
        "-ldl"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "compiler: /usr/bin/g++"
    },
    {
      "label": "run",
      "type": "shell",
      "command": "${workspaceFolder}/src/gravity_sim_3Dgrid",
      "dependsOn": "build",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
